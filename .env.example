# ----------------------------------------------------------------------------
# Firebase configuration (Vite-exposed; values are visible in the browser)
# ----------------------------------------------------------------------------
# IMPORTANT: Restrict the API key by HTTP referrer in the Firebase Console.
# https://console.cloud.google.com/apis/credentials → Edit API key → Application restrictions
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=restpossys.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=restpossys
VITE_FIREBASE_STORAGE_BUCKET=restpossys.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ----------------------------------------------------------------------------
# Vite dev server
# ----------------------------------------------------------------------------
# Comma-separated extra hostnames to allow on `vite` / `vite preview`.
# `localhost` and `127.0.0.1` are always allowed.
# Example: VITE_ALLOWED_HOSTS=staging.myhost.com,*.tunnel.dev
VITE_ALLOWED_HOSTS=
